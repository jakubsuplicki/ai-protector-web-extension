def pre_tool_gate_node(state: dict[str, Any]) -> dict[str, Any]:
    """LangGraph node: pre-tool security gate.

    Expects state to contain:
      - role: str (current user role)
      - tool: str (tool being called)
      - tool_args: dict (tool arguments)

    Adds to state:
      - gate_result: dict with allowed, reason, requires_confirmation
    """
    gate = PreToolGate()
    role = state.get("role", "unknown")
    tool = state.get("tool", "unknown")
    args = state.get("tool_args", {})

    result = gate.check(role, tool, args)
    state["gate_result"] = result
    return state


def post_tool_gate_node(state: dict[str, Any]) -> dict[str, Any]:
    """LangGraph node: post-tool security gate.

    Expects state to contain:
      - tool_output: str (raw tool output)

    Adds to state:
      - scan_result: dict with clean, findings
    """
    gate = PostToolGate()
    output = state.get("tool_output", "")

    result = gate.scan(output)
    state["scan_result"] = result
    return state


