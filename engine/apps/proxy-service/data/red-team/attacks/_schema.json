{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Attack Category File v2",
  "description": "Schema for red-team attack category files (v2) with preconditions, postconditions, and apply_on surfaces.",
  "type": "object",
  "required": ["category", "version", "description", "defaults", "attacks"],
  "properties": {
    "category": { "type": "string", "pattern": "^[a-z_]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "defaults": {
      "type": "object",
      "required": ["requires_proxy", "supported_modes", "observable_surfaces", "confidence_class"],
      "properties": {
        "requires_proxy": { "type": "boolean" },
        "supported_modes": {
          "type": "array",
          "items": { "type": "string", "enum": ["black_box", "proxied", "instrumented"] },
          "minItems": 1
        },
        "observable_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["user_input", "pipeline_result", "forwarded_request", "final_response"]
          },
          "minItems": 1
        },
        "confidence_class": { "type": "string", "enum": ["deterministic", "soft"] }
      }
    },
    "attacks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/attack" }
    }
  },
  "definitions": {
    "attack": {
      "type": "object",
      "required": [
        "id", "title", "prompt", "tags", "severity",
        "expected_proxy_action", "expected_security_outcome",
        "supported_modes", "requires_proxy",
        "risk_surface", "breach_surface", "breach_class",
        "success_criteria", "detector",
        "description", "added"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]+-\\d{3}$" },
        "title": { "type": "string", "minLength": 3 },
        "prompt": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "expected_proxy_action": {
          "type": "string",
          "enum": ["BLOCK", "MODIFY", "ALLOW"]
        },
        "expected_security_outcome": {
          "type": "string",
          "enum": ["blocked", "safe", "breached"]
        },
        "supported_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["black_box", "proxied", "instrumented"]
          },
          "minItems": 1
        },
        "requires_proxy": { "type": "boolean" },
        "risk_surface": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "breach_surface": { "type": "string" },
        "breach_class": {
          "type": "string",
          "enum": ["full", "partial"]
        },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "detector": {
          "type": "object",
          "required": ["postconditions"],
          "properties": {
            "preconditions": {
              "type": "array",
              "items": { "$ref": "#/definitions/condition" }
            },
            "postconditions": {
              "type": "array",
              "items": { "$ref": "#/definitions/condition" },
              "minItems": 1
            }
          }
        },
        "fix_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["playground", "compare", "agent_threats", "jailbreakbench", "manual"]
        },
        "source_id": { "type": ["string", "null"] },
        "added": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["variant_id", "prompt"],
            "properties": {
              "variant_id": { "type": "string" },
              "prompt": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "condition": {
      "type": "object",
      "required": ["name", "apply_on", "type", "config", "confidence_class"],
      "properties": {
        "name": { "type": "string" },
        "apply_on": {
          "type": "string",
          "enum": ["user_input", "pipeline_result", "forwarded_request", "final_response"]
        },
        "type": {
          "type": "string",
          "enum": [
            "exact_match", "regex", "keyword",
            "canary", "tool_call_detect", "json_assertion",
            "refusal_pattern", "heuristic"
          ]
        },
        "config": { "type": "object" },
        "confidence_class": {
          "type": "string",
          "enum": ["deterministic", "soft"]
        },
        "required_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["black_box", "proxied", "instrumented"]
          },
          "description": "If set, this condition only applies in these modes"
        },
        "requires_canary": { "type": "boolean" },
        "note": { "type": "string" }
      }
    }
  }
}
