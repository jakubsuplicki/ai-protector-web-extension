{
  "name": "ai-protector-extension",
  "description": "AI Protector DLP browser extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "gen:icons": "node scripts/gen-icons.mjs",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.3",
    "wxt": "0.20.21"
  }
}
