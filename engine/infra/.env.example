# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=ai_protector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Mode ───────────────────────────────────────────────
# "demo" = MockProvider when no API key (no Ollama needed)
# "real" = Ollama or external provider required
MODE=demo

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL=llama3.1:8b

# ── Langfuse ──────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# ── Proxy Service ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_protector
DEFAULT_POLICY=balanced

# ── Agent Demo ────────────────────────────────────────
PROXY_BASE_URL=http://proxy-service:8000/v1

# ── Test Agents ───────────────────────────────────────
PROXY_URL=http://proxy-service:8000
PROXY_POLICY=balanced
OLLAMA_HOST=http://host.docker.internal:11434

# ── Agent Tracing (leave empty — auto-set by /load-config) ──
# Set these to pre-assign agent IDs for trace collection.
# If empty, agents pick up the ID when /load-config is called.
AGENT_ID_DEMO=
AGENT_ID_PYTHON=
AGENT_ID_LANGGRAPH=

# ── Red Team Benchmark ────────────────────────────────
# 64-hex-char AES-256 key for encrypting auth secrets at rest.
# Auto-generated by `make init` / `make demo` if empty.
BENCHMARK_SECRET_KEY=
