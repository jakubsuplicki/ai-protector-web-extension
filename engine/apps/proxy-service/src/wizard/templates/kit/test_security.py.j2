def _check_permission(role: str, tool: str) -> bool:
    """Walk RBAC inheritance to check if role can access tool."""
    roles = RBAC.get("roles", {})
    visited: set[str] = set()
    current = role

    while current and current not in visited:
        visited.add(current)
        role_cfg = roles.get(current, {})
        tools = role_cfg.get("tools", {})
        if tool in tools:
            return True
        current = role_cfg.get("inherits")

    return False


def _get_tool_config(role: str, tool: str) -> dict | None:
    """Get tool config for a role (walking inheritance)."""
    roles = RBAC.get("roles", {})
    visited: set[str] = set()
    current = role

    while current and current not in visited:
        visited.add(current)
        role_cfg = roles.get(current, {})
        tools = role_cfg.get("tools", {})
        if tool in tools:
            return tools[tool]
        current = role_cfg.get("inherits")

    return None


